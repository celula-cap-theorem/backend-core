{
  "ConnectionStrings": {
    "Catalog": "Server=<DB_HOST>;Database=<DB_NAME>;User Id=<DB_USER>;Password=<DB_PASSWORD>"
  },
  "Jwt": {
    "Key": "<JWT_SIGNING_KEY_MIN_32_CHARS>",
    "Issuer": "cap-theorem-backend",
    "Audience": "cap-theorem-clients",
    "ExpirationMinutes": "60"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Google": { "ClientId": "<GOOGLE_CLIENT_ID>", "ClientSecret": "<GOOGLE_CLIENT_SECRET>" },
    "GitHub": { "ClientId": "<GB_CLIENT_ID>", "ClientSecret": "<GB_CLIENT_SECRET>" }
  },
  "MySqlAdmin": {
    "Host": "<MYSQL_HOST>",
    "ConnectionString": "Server=<MYSQL_HOST>;Uid=<ADMIN_USER>;Pwd=<ADMIN_PASSWORD>"
  },
  "Frontend": { "PostLoginRedirect": "https://cap-theorem.andrescortes.dev/auth/callback" },
  "AllowedHosts": "*"
}
